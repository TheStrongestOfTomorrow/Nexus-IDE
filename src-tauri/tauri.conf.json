{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Nexus IDE",
    "version": "5.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "shell": {
        "all": true,
        "execute": true,
        "sidecar": true,
        "scope": [
          {
            "name": "sh",
            "cmd": "sh",
            "args": true
          },
          {
            "name": "cmd",
            "cmd": "cmd",
            "args": true
          },
          {
            "name": "powershell",
            "cmd": "powershell",
            "args": true
          }
        ]
      },
      "dialog": {
        "all": true,
        "open": true,
        "save": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://**", "http://**"]
      },
      "notification": {
        "all": true
      },
      "os": {
        "all": true
      },
      "path": {
        "all": true
      },
      "process": {
        "all": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "Copyright © 2025 TheStrongestOfTomorrow",
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.nexus-ide.app",
      "longDescription": "Nexus IDE v5.1 — The AI-First, Browser-Based IDE. A modern, high-performance development environment with AI integration from 12+ providers, WebContainer support, workspace persistence via IndexedDB, beginner-friendly UI mode, VS Code-like experience, and cross-platform support for Web, Tauri Desktop, and Capacitor Mobile.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "signingIdentity": null,
        "minimumSystemVersion": "10.15"
      },
      "resources": [],
      "shortDescription": "The AI-First, Browser-Based IDE",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "bannerPath": null,
          "dialogImagePath": null
        }
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https: wss: ws:; font-src 'self' data:; worker-src 'self' blob:;"
    },
    "updater": {
      "active": true,
      "endpoints": [],
      "dialog": true,
      "pubkey": ""
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Nexus IDE",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  }
}
