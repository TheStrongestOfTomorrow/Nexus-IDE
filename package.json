{
  "name": "@TheStrongestOfTomorrow/nexus-ide",
  "version": "5.4.0",
  "description": "The AI-First, Browser-Based IDE - A modern, high-performance web-based IDE with AI integration, VS Code-like experience, and support for multiple AI providers.",
  "author": "TheStrongestOfTomorrow",
  "license": "MIT",
  "type": "module",
  "main": "server.ts",
  "bin": {
    "nexus-ide": "./bin/nexus-ide.js"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    "server.ts",
    "vite.config.ts",
    "tsconfig.json",
    "index.html",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ide",
    "code-editor",
    "web-ide",
    "ai",
    "monaco-editor",
    "vscode-alternative",
    "browser-ide",
    "code-editor",
    "ai-assistant",
    "development",
    "programming",
    "online-ide",
    "webcontainer",
    "nodejs",
    "stackblitz"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheStrongestOfTomorrow/Nexus-IDE.git"
  },
  "bugs": {
    "url": "https://github.com/TheStrongestOfTomorrow/Nexus-IDE/issues"
  },
  "homepage": "https://github.com/TheStrongestOfTomorrow/Nexus-IDE#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "npm run build && npx serve dist -p 3000",
    "deploy": "npm run build && npx gh-pages -d dist",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "capacitor:android": "npm run build && npx cap sync android && npx cap open android",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^8.3.0",
    "@google/generative-ai": "^0.21.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^1.5.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "glob": "^13.0.6",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.12.3",
    "motion": "^12.23.24",
    "openai": "^6.22.0",
    "pixi.js": "^8.16.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@tauri-apps/cli": "^1.5.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
